# ============================================================
# Studybo Instagram Intelligence — .gitignore
# ============================================================

# ── Secret & Environment Files ───────────────────────────────
# NEVER commit .env — it contains DB credentials and API tokens
.env
.env.local
.env.production
.env.staging
.env.*.local

# ── Node Modules ─────────────────────────────────────────────
node_modules/
frontend/node_modules/

# ── Build Output ──────────────────────────────────────────────
frontend/dist/
frontend/dist-ssr/
frontend/.vite/

# ── Logs ─────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── OS & Editor Files ─────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/settings.json
*.swp
*.swo

# ── Misc ──────────────────────────────────────────────────────
*.pid
*.seed
*.pid.lock
.npm
coverage/
